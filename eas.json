{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": true
      },
      "env": {
        "SENTRY_ORG": "cinescenes",
        "SENTRY_PROJECT": "react-native"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "SENTRY_ORG": "cinescenes",
        "SENTRY_PROJECT": "react-native"
      },
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {}
  }
}
